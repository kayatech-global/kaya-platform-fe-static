{
  "version": "0.2.0",
  "configurations": [
    {
      // Launch Next dev in kaya-platform-admin-frontend (server-side debug)
      "name": "Kaya Admin FE: Dev (server debug)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],                // runs: next dev --turbopack
      "cwd": "${workspaceFolder:kaya-platform-admin-frontend}",
      "env": { "NODE_OPTIONS": "--inspect=9229" },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "autoAttachChildProcesses": true,      // Turbopack spawns workers
      "smartStep": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder:kaya-platform-admin-frontend}/**",
        "!**/node_modules/**"
      ],
      "serverReadyAction": {
        // Matches your output lines:
        //   - Local:        http://localhost:3000
        //   - Network:      http://10.223.179.7:3000
        // Captures the URL so we can open the exact one (incl. custom ports)
        "pattern": "(?:Local|Network):\\s+(https?://[\\w\\.-]+:\\d+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      // Optional: Launch Chrome manually for client-side debugging
      "name": "Kaya Admin FE: Chrome attach",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder:kaya-platform-admin-frontend}",
      "sourceMaps": true
    },
    {
      // Attach to a Next dev already started elsewhere with --inspect=9229
      "name": "Kaya Admin FE: Attach Node (9229)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "smartStep": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },

    // --- Optional: production debug (after build) ---
    {
      "name": "Kaya Admin FE: Start (prod, server debug)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["start"],              // runs: next start
      "cwd": "${workspaceFolder:kaya-platform-admin-frontend}",
      "env": { "NODE_OPTIONS": "--inspect=9229", "PORT": "3000" },
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true,
      "smartStep": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "preLaunchTask": "Kaya Admin FE: Build",
      "serverReadyAction": {
        // next start also prints the Local/Network lines
        "pattern": "(?:Local|Network):\\s+(https?://[\\w\\.-]+:\\d+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    }
  ],
  "compounds": [
    {
      "name": "Kaya Admin FE: Full-stack debug",
      "configurations": [
        "Debug TypeScript Express"
      ]
    }
  ]
}
